@incollection{ WOS:000293772800011,
Author = {Ye, Guoyou and Ogbonnaya, Francis and van Ginkel, Maarten},
Editor = {Singh, RK and Singh, R and Ye, GY and Selvi, A and Rao, GP},
Title = {Marker-Assisted Recurrent Backcrossing in Cultivar Development},
Booktitle = {MOLECULAR PLANT BREEDING: PRINCIPLE, METHOD AND APPLICATION},
Year = {2010},
Pages = {295-319},
Abstract = {Marker-assisted recurrent backcrossing (MARB), the combined use of
   marker-assisted selection (MAS) and recurrent backcrossing, is a
   versatile method for plant breeding and genetic studies. The benefits of
   MARB are well demonstrated and documented in theoretical and simulation
   studies, and confirmed by empirical applications. In MARB, markers are
   used during recurrent backcrossing to select for the presence of the
   target gene (foreground selection), to select against the donor genome
   contribution (background selection) to reduce the introgressed segment's
   size and thus potential linkage drag. MARB reduces the number of
   backcrossing needed to recover most of the recurrent parent genome in
   3-4 generations, while one or two target genes are introgressed from the
   donor. For foreground selection markers are most useful for traits that
   are expensive and/or difficult to measure. Linkage drag associated with
   the target gene(s), when present, is difficult if not impossible to
   remove by phenotypic selection. In this chapter, we summarised some of
   the theoretical and simulation results of MARB, and provided
   comprehensive summary of the use of MARB in practical crop breeding.},
Publisher = {STUDIUM PRESS LLC},
Address = {PO BOX 722200, HOUSTON, TX 77072 USA},
Type = {Article; Book Chapter},
Language = {English},
Affiliation = {Ye, GY (Corresponding Author), Dept Primary Ind Victoria, Biosci Div, Bundoora Ctr, 1 Pk Dr, Bundoora, Vic 3086, Australia.
   Ye, Guoyou, Dept Primary Ind Victoria, Biosci Div, Bundoora Ctr, Bundoora, Vic 3086, Australia.
   Ye, Guoyou, Mol Plant Breeding Cooperat Res Ctr, Bundoora, Vic 3086, Australia.
   Ogbonnaya, Francis; van Ginkel, Maarten, Int Ctr Agr Res Dry Areas, Aleppo, Syria.},
ISBN = {978-1-933699-49-3},
