@article{ WOS:A1996VD38800006,
Author = {Dourleijn, J},
Title = {A case study of subset selection in sugar beet breeding},
Journal = {JOURNAL OF STATISTICAL PLANNING AND INFERENCE},
Year = {1996},
Volume = {54},
Number = {3},
Pages = {323-344},
Month = {SEP 30},
Abstract = {In this paper we study the application of subset selection in the
   process of breeding sugar beet varieties. There, series of field
   experiments with unbalanced, incomplete block designs are performed. The
   selection is mainly based on mean performance variety values, but also
   on variety values at the individual sites. The varieties are selected on
   the basis of various characters. To be able to apply subset selection,
   several obstacles had to be taken. Selection rules were modified and
   software was developed to approximate the necessary selection constants
   using simulation. Also, software was developed to execute the selection
   rules. It is concluded that subset selection can be successfully used in
   the breeding practice, although it cannot replace the experienced plant
   breeder.},
