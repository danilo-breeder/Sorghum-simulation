@article{ WOS:000254487000015,
Author = {Rodrigues Nunes, Jose Airton and Patto Ramalho, Magno Antonio and
   Ferreira, Daniel Furtado},
Title = {Inclusion of genetic relationship information in the pedigree selection
   method using mixed models},
Journal = {GENETICS AND MOLECULAR BIOLOGY},
Year = {2008},
Volume = {31},
Number = {1},
Pages = {73-78},
Month = {MAR},
Abstract = {We used a mixed model approach and computer simulation to evaluate the
   inclusion of parentage information as determined by the genealogy
   established in the pedigree method. The simulations were based on a
   purely additive genetic model for one quantitative trait of 20 unlinked
   segregating loci with equal effects and an allelic frequency of 0.5 for
   heritability values of 10\%, 25\%, 50\% and 75\% for selection based on
   an F-4:5 progeny mean. We simulated 1000 experiments for each
   heritability value, corresponding to the evaluation of 256 F-4:5
   progenies. The phenotypic values of the progenies were analyzed
   according to two models, one ignoring and one considering the additive
   genetic parentage among the progenies. The additive relationship
   coefficients among F-4:5 progenies ranged from 0.0 to 1.75. The
   evaluated selection procedures were the phenotypic progeny mean (M) and
   the best linear unbiased predictor including parentage (BLUPA). The
   inclusion of parentage among progenies using the BLUPA procedure
   resulted in higher selection gains than when the relationship
   information was ignored, which possibly recompenses the additional work
   invested to obtain these records, above all in the case of low -
   heritability traits.},
