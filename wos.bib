@inproceedings{ WOS:000170185300001,
Author = {Basford, KE},
Editor = {Fernholz, LT and Morgenthaler, S and Stahel, W},
Title = {Statistical interaction with quantitative geneticists to enhance impact
   from plant breeding programs},
