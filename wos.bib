@inproceedings{ WOS:A1997BH23W00004,
Author = {Lindquist, JL and Kropff, MJ},
Editor = {Kropff, MJ and Teng, PS and Aggarwal, PK and Bouman, BAM and Jones, JW and vanLaar, HH},
Title = {Improving rice tolerance to barnyardgrass through early crop vigour:
   Simulations with INTERCOM},
Booktitle = {APPLICATIONS OF SYSTEMS APPROACHES AT THE FIELD LEVEL: PROCEEDINGS OF
   THE SECOND INTERNATIONAL SYMPOSIUM ON SYSTEMS APPROACHES FOR
   AGRICULTURAL DEVELOPMENT, VOL 2},
Series = {SYSTEMS APPROACHES FOR SUSTAINABLE AGRICULTURAL DEVELOPMENT},
Year = {1997},
Volume = {6},
Pages = {53-62},
Note = {2nd International Symposium on Systems Approaches for Agricultural
   Development - Applications of Systems Approaches at the Field Level, INT
   RICE RES INST, LOS BANOS, PHILIPPINES, DEC 06-08, 1995},
Organization = {Int Rice Res Inst; Int Consortium Agr Syst Applicat; Simulat \& Syst
   Anal Rice Prod Project},
Abstract = {Crop yields on-farm rarely approach their production potential, partly
   as a result of growth reduction due to weed interference. The ability of
   rice to maintain yield in the presence of barnyardgrass (a measure of
   tolerance) may be improved if the time between emergence or
   transplanting and canopy closure is decreased. This may be accomplished
   through manipulation of crop population density and spatial arrangement,
   or improvement of early crop vigour. A simulation model of
   rice-bamyardgrass competition for light (INTERCOM) was used to evaluate
   the influence of increased early vigour in rice on its tolerance to
   bamyardgrass. Simulations suggest that increasing early leaf area
   expansion and height growth rates in rice will reduce yield loss.
   Correlation between early crop vigour and rice tolerance to
   barnyardgrass in the field is warranted. Rice cultivars with improved
   tolerance may improve yield stability in the presence of low
   bamyardgrass populations.},
Publisher = {KLUWER ACADEMIC PUBL},
