Year = {2001},
Pages = {1-15},
Note = {Workshop on Statistics and the Sciences, ASCONA, SWITZERLAND, MAY 23-28,
   1999},
Organization = {Minerva Res Fdn; Swiss Fed Inst Technol Lausanne; Swiss Fed Inst Technol
   Zurich},
Abstract = {Plant breeding programs operate to achieve genetic improvement in a
   target population of environments. This process relies heavily on
   successfully selecting superior genotypes based on their performance in
   multi-environment trials that should be designed to represent the
   relevant target conditions. Genotype by environment (GxE) interactions
   can complicate these selection decisions, particularly when crossover
   interactions are a large component of the GxE interactions. This has
   been found to be the case for a range of crops and pastures in
   Australia. Long-term collaboration between statisticians and
   quantitative geneticists has resulted in a joint research program
   focussed on procedures to accommodate G x E interactions, As the
   objective is to develop decision support systems that assist the plant
   breeder to make selections, the integration of theory with practice is
   continually stressed. Some outcomes from this research program are
   described, thereby showing how such interaction enhances impact from
   plant breeding programs.},
