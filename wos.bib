@article{ WOS:000229344800018,
Author = {Tan, ZY and Xia, YY and Zhao, MW and Liu, XD},
Title = {Monte Carlo simulation of interactions between energetic electron and
   cellulose film},
Journal = {APPLIED SURFACE SCIENCE},
Year = {2005},
Volume = {246},
Number = {1-3},
Pages = {117-125},
Month = {JUN 15},
Abstract = {Monte Carlo method of simulating the interactions between energetic
   electron and organic compound is presented. This method is based on the
   Mott cross-section and Rutherford cross-section for the elastic
   scattering of electrons in different energy regions and the
   cross-section derived by dielectric response theory with exchange effect
   included for the inelastic scattering of electrons. The comparisons have
   been done to show the reliability of the described method. Using this
   method, the systematic calculations of the mean energy loss of
   transmitted electrons through the cellulose films with different
   thickness for different primary energies have been performed. The
   dependence of the mean energy loss of transmitted electrons on cellulose
   film thickness is analyzed. A method to evaluate the mean energy loss of
   the transmitted electrons for the cellulose film with a fixed thickness
   at a given primary energy is proposed. (c) 2004 Elsevier B.V. All rights
   reserved.},
