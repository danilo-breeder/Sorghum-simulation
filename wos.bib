@article{ WOS:000345970200024,
Author = {Charmet, Gilles and Storlie, Eric and Oury, Francois Xavier and Laurent,
   Valerie and Beghin, Denis and Chevarin, Laetitia and Lapierre, Annie and
   Perretant, Marie Reine and Rolland, Bernard and Heumez, Emmanuel and
   Duchalais, Laure and Goudemand, Ellen and Bordes, Jacques and Robert,
   Olivier},
Title = {Genome-wide prediction of three important traits in bread wheat},
Journal = {MOLECULAR BREEDING},
Year = {2014},
Volume = {34},
Number = {4},
Pages = {1843-1852},
Month = {DEC},
Abstract = {Five genomic prediction models were applied to three wheat agronomic
   traits-grain yield, heading date and grain test weight-in three breeding
   populations, each comprising about 350 doubled haploid or recombinant
   inbred lines evaluated in three locations during a 3-year period. The
   prediction accuracy, measured as the correlation between genomic
   estimated breeding value and observed trait, was in the range of
   previously published values for yield (r = 0.2-0.5), a trait with
   relatively low heritability. Accuracies for heading date and test
   weight, with relatively high heritabilities, were about 0.70. There was
   no improvement of prediction accuracy when two or three breeding
   populations were merged into one for a larger training set (e.g., for
   yield r ranged between 0.11 and 0.40 in the respective populations and
   between 0.18 and 0.35 in the merged populations). Cross-population
   prediction, when one population was used as the training population set
   and another population was used as the validation set, resulted in no
   prediction accuracy. This lack of cross-population prediction accuracy
   cannot be explained by a lower level of relatedness between populations,
   as measured by a shared SNP similarity, since it was only slightly lower
   between than within populations. Simulation studies confirm that
   cross-prediction accuracy decreases as the proportion of shared QTLs
   decreases, which can be expected from a higher level of QTL x
   environment interactions.},
