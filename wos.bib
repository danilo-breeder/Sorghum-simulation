@article{ WOS:A1993LV98300005,
Author = {CHENG, CC and WANN, SS},
Title = {AN APPLICATION OF EROSION PRODUCTIVITY INDEX SIMULATOR TO GRASSLAND
   WATERSHEDS IN TAIWAN},
Journal = {JOURNAL OF THE AGRICULTURAL ASSOCIATION OF CHINA},
Year = {1993},
Number = {161},
Pages = {47-61},
Month = {MAR},
Abstract = {Soil productivity decrease is related to the erosion of the soil itself.
   Cumulative potential productivity of the soil can be calculated measured
   as the percentage of the potential productivity exhausted to the amount
   of the erosion soil over a time period. Based upon relationships between
   the percentage of potential productivity exhausted and the cumulative
   amount of the soil erosion, soil managers and policymakers may predict
   the maximum erosion rate according to the potential productivity
   capacity of the soil set up for a given time period,
   The erosion-productivity index simulator (EPIS) was developed in USA by
   using output information from the EPIC package in 1984. The information
   of EPIS can be used to assist farmers in selecting suitable
   soil-conserving program. Simulations of EPIC and EPIS have been
   performed on many test sites of continental region in USA and other
   countries. Are such simulations applicable to watersheds in Taiwan ?
   This study evaluates the suitability of such simulations on pasture
   watersheds in Taiwan.
   The data files of crop parameters contain the data of growth
   characteristics and plant breeding tailored to climatic zones in a plant
   growth model. Pangolagrass is not included in 23 crops listed in the
   Crop. dat of EPIC. The results of this study provide parameters of the
   Pangolagrass listed as C 38 in the file of Crop. dat.
   Insignificant difference between the predicted and the measured yields
   of Pangolagrass indicated that the EPIC model could be used for
   watersheds in Taiwan. Types and cost of soil conservation programs can
   be determined by using simulation information of EPIC.
   Results of EPIS simulation for various slopes of Pangolagrass watersheds
   in this study suggests that land slope has a great influence on the
   erosion-productivity index and this factor should be considered in
   evaluating glassland development.},
