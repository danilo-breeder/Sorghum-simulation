@article{ WOS:000084983100002,
Author = {Young, ND},
Title = {A cautiously optimistic vision for marker-assisted breeding},
Journal = {MOLECULAR BREEDING},
Year = {1999},
Volume = {5},
Number = {6},
Pages = {505-510},
Month = {DEC},
Abstract = {Even though marker-assisted selection now plays a prominent role in the
   field of plant breeding, examples of successful, practical outcomes are
   rare. It is clear that DNA markers hold great promise, but realizing
   that promise remains elusive. Despite innovations like better marker
   systems and improved genetic mapping strategies, most marker
   associations are not sufficiently robust for successful marker-assisted
   selection. In large part this is due to inadequate experimental design.
   Molecular breeders must reassess their research programs so that DNA
   marker work leads to useful selection tools and valuable germplasm. As
   molecular breeders adopt more rigorous experimental guidelines and
   ambitious goals, they also need to integrate the growing body of
   knowledge from genomics and bioinformatics.},
