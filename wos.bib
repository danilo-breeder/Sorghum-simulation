@article{ WOS:A1982NX51600046,
Author = {DUDLEY, JW},
Title = {THEORY FOR TRANSFER OF ALLELES},
Journal = {CROP SCIENCE},
Year = {1982},
Volume = {22},
Number = {3},
Pages = {631-637},
Abstract = {An attempt was made to provide a theoretical framework for developing
   methods for incorporation of favorable alleles governing quantitative
   traits from exotic germplasm into adapted populations and to present
   computer simulation results evaluating the theory. Theoretical
   considerations suggest that the results apply to either improvement of
   an inbred line by adding favorable alleles from another line or to
   addition of favorable alleles from an exotic source to an adapted
   synthetic. If one parent has more loci containing favorable alleles than
   the other, at least 1 generation of backcrossing to the recipient
   population prior to initiation of selection will enhance the probability
   of recovering a population which outperforms the better parent or a line
   better than the best line which could be isolated from the better
   parent. Selection starting in the appropriate generation will usually be
   necessary to either improve the population mean to the desired level or
   to increase to a reasonable level the probability of obtaining a
   superior inbred line. The more diverse the parents, the more useful 1 or
   more generations of backcrossing becomes. {[}Examples were provided
   using Glycine max, Zea mays, Avena sp. in plant breeding.].},
