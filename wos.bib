@article{ WOS:000221617500002,
Author = {Tóth, S and Pepó, P},
Title = {Studies on basic maize breeding stocks},
Journal = {NOVENYTERMELES},
Year = {2003},
Volume = {52},
Number = {6},
Pages = {609-621},
Month = {DEC},
Abstract = {Due to specific breeding aims and gene erosion the genetic basis of
   maize breeding has decreased significantly in Hungary in recent decades,
   with well-known unfavourable effects. Many foreign hybrids are used in
   maize production, the genetic background of which is restricted a few
   inbred lines, In order to decrease the genetic vulnerability, it is very
   important to widen the base for maize breeding using various methods.
   One way of increasing genetic variability is through treatment with
   various mutagens.
   Within a programme started in 1979-80, F-1 maize hybrid seeds were
   treated with radiation from the Co-60 isotope. Later, in 1985, the trial
   was expanded and the seeds were treated with radiation from fast
   neutrons at the Atomic Research Institute of the Hungarian Academy of
   Sciences in Debrecen. Selected mutant lines developed in this way have
   been self-pollinated for several years. These homogeneous lines formed
   the plant material in the present trials, based on two complete diallel
   systems ('A' and `B').
   The two diallel systems were examined by applying a modified version of
   the DIALLEL Analysis and Simulation programme (BUROW-COORS, 1993),
   according to the GRIFFING 1 method (1956).
   In the case of diallel system `A', line A13 and its hybrids (A3 and A10)
   had the highest combining abilities, compared to the standard and the
   other hybrids, and produced outstanding yields in all three years
   examined.
   Lines B15 and B16, which had excellent GCA, were always found among the
   parents of hybrids B3, B6, B9 and B10, which had outstanding
   productivity. This was proved by the results of all the three years. Due
   to the low productivity observed in all three years, hybrids B1 and B4
   and their parent lines, which bad low GCA values, were eliminated from
   further breeding projects. The others were able to equal or exceed the
   productivity of the standard hybrid in all three years, so the best of
   them will be subjected to further testing and, if satisfactory results
   are obtained, in the development of new hybrids in the future.},
