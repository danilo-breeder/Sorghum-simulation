@article{ WOS:000431833200002,
Author = {Morgante, Fabio and Huang, Wen and Maltecca, Christian and Mackay, Trudy
   F. C.},
Title = {Effect of genetic architecture on the prediction accuracy of
   quantitative traits in samples of unrelated individuals},
Journal = {HEREDITY},
