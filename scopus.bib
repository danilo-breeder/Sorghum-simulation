	affiliations = {Max Planck Institute for Plant Breeding Research, Department for Plant Developmental Biology, 50829 Cologne, Germany; Department of Biological Sciences, Institute of Genetics/Epigenetics, University of Saarland, 66123 Saarbrücken, Campus Saarbrücken, Germany; Max Planck Institute for Developmental Biology, Department of Molecular Biology, 72076 Tübingen, Germany},
	abstract = {Mapping-by-sequencing combines genetic mapping with whole-genome sequencing in order to accelerate mutant identification. However, application of mapping-by-sequencing requires decisions on various practical settings on the experimental design that are not intuitively answered. Following an experimentally determined recombination landscape of Arabidopsis and next generation sequencing-specific biases, we simulated more than 400,000 mapping-by-sequencing experiments. This allowed us to evaluate a broad range of different types of experiments and to develop general rules for mapping-by-sequencing in Arabidopsis. Most importantly, this informs about the properties of different crossing scenarios, the number of recombinants and sequencing depth needed for successful mapping experiments. © 2013 James et al.; licensee BioMed Central Ltd.},
