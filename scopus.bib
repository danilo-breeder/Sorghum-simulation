	affiliations = {Departamento de Estatística, Universidade Federal de Viçosa (UFV), 36570-000, Viçosa, MG, Brazil; Departamento de Agronomia, Universidade Federal de Rondônia (UNIR), Rolim de Moura, RO, Brazil; Departamento de Fitotecnia, UFV, Viçosa, MG, Brazil; Programa de Pós-graduação em Genética e Melhoramento, UFV, Viçosa, MG, Brazil},
