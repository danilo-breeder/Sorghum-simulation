@ARTICLE{Macchiavelli20011513,
	author = {Macchiavelli, R. and Beaver, J.S.},
	title = {Effect of number of seed bulked and population size on genetic variability when using the multiple-seed procedure of SSD},
	year = {2001},
	journal = {Crop Science},
	volume = {41},
