	affiliations = {Department of Plant Sciences, University of Tennessee, 112 Plant Biotechnology Building, Knoxville, 37996-4500, TN, United States; United States Department of Agriculture (USDA) Agricultural Research Service (ARS), Western Regional Research Center, 800 Buchanan Street, Albany, 94710, CA, United States; Plant Systems-Production, USDA National Institute of Food and Agriculture (NIFA), Beacon Complex, United States; USDA ARS, Crop Improvement and Protection Research Unit, 1636 E Alisal Street, Salinas, 93905, CA, United States},
	abstract = {Switchgrass can be used as an alternative source for bioenergy production. Many breeding programs focus on the genetic improvement of switchgrass for increasing biomass yield. Quantitative trait loci (QTL) mapping can help to discover marker-trait associations and accelerate the breeding process through marker-assisted selection. To identify significant QTL, this study mapped 7 hybrid populations and one combined of 2 hybrid populations (30–96 F1s) derived from Alamo and Kanlow genotypes. The populations were evaluated for biomass yield, plant height, and crown size in a simulated-sward plot with 2 replications at 2 locations in Tennessee from 2019 to 2021. The populations showed significant genetic variation for the evaluated traits and exhibited transgressive segregation. The 17,251 single nucleotide polymorphisms (SNPs) generated through genotyping-by-sequencing (GBS) were used to construct a linkage map using a fast algorithm for multiple outbred families. The linkage map spanned 1,941 cM with an average interval of 0.11 cM between SNPs. The QTL analysis was performed on evaluated traits for each and across environments (year and location) that identified 5 QTL for biomass yield (logarithm of the odds, LOD 3.12–4.34), 4 QTL for plant height (LOD 3.01–5.64), and 7 QTL for crown size (LOD 3.0–4.46) (P ≤ 0.05). The major QTL for biomass yield, plant height, and crown size resided on chromosomes 8N, 6N, and 8K explained phenotypic variations of 5.6, 5.1, and 6.6%, respectively. SNPs linked to QTL could be incorporated into marker-assisted breeding to maximize the selection gain in switchgrass breeding. © The Author(s) 2023.},
	author_keywords = {bioenergy; biomass; environment; genome; genomics; hybrid; phenotype; plant genetics},
	keywords = {Biomass; Genetic Linkage; Humans; Panicum; Phenotype; Plant Breeding; Polymorphism, Single Nucleotide; Quantitative Trait Loci; algorithm; article; bioenergy; biomass; chromosome 8; genetic association; genetic linkage; genetic variation; genomics; genotype; genotyping; marker assisted breeding; nonhuman; Panicum virgatum; phenotypic variation; plant genetics; plant height; plant yield; quantitative analysis; quantitative trait locus; simulation; single nucleotide polymorphism; Tennessee; biomass; genetics; human; Panicum; phenotype; plant breeding},
	correspondence_address = {S.L. Shrestha; Department of Plant Sciences, University of Tennessee, Knoxville, 112 Plant Biotechnology Building, 37996-4500, United States; email: sshres18@utk.edu},
