	keywords = {Finland; Hordeum; Hordeum vulgare subsp. vulgare; agronomy; barley; carbon dioxide; climate change; climate prediction; crop production; cropping practice; cultivar; drought resistance; fertilizer application; global warming; growing season; growth modeling; growth response; latitude; low temperature; plant breeding; sandy soil; soil profile; sowing date; water stress; yield response},
