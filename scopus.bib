	doi = {10.1186/1471-2164-11-204},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-77952595655&doi=10.1186%2f1471-2164-11-204&partnerID=40&md5=9162c65a1fc30aae2eafd59299269a22},
	affiliations = {Dipartimento di Matematica e Informatica, Università di Udine, 33100 Udine, Via delle Scienze 206, Italy; Istituto di Genomica Applicata, Parco Scientifico e Tecnologico di Udine Luigi Danieli, 33100 Udine, Via J Linussio 51, Italy; IASMA Research and Innovation Centre, Foundation Edmund Mach, 38010 San Michele all'Adige (TN), Via E Mach 1, Italy; Dipartimento di Scienze Agrarie ed Ambientali, Università degli Studi di Udine, 33100 Udine, Via delle Scienze 208, Italy; Keygene NV, 6700 Wageningen, PO Box 216, Netherlands; Dipartimento di Biologia, Università degli Studi di Padova, 35121 Padova, Via Ugo Bassi 58b, Italy},
	abstract = {Background: Most of the grapevine (Vitis vinifera L.) cultivars grown today are those selected centuries ago, even though grapevine is one of the most important fruit crops in the world. Grapevine has therefore not benefited from the advances in modern plant breeding nor more recently from those in molecular genetics and genomics: genes controlling important agronomic traits are practically unknown. A physical map is essential to positionally clone such genes and instrumental in a genome sequencing project.Results: We report on the first whole genome physical map of grapevine built using high information content fingerprinting of 49,104 BAC clones from the cultivar Pinot Noir. Pinot Noir, as most grape varieties, is highly heterozygous at the sequence level. This resulted in the two allelic haplotypes sometimes assembling into separate contigs that had to be accommodated in the map framework or in local expansions of contig maps. We performed computer simulations to assess the effects of increasing levels of sequence heterozygosity on BAC fingerprint assembly and showed that the experimental assembly results are in full agreement with the theoretical expectations, given the heterozygosity levels reported for grape. The map is anchored to a dense linkage map consisting of 994 markers. 436 contigs are anchored to the genetic map, covering 342 of the 475 Mb that make up the grape haploid genome.Conclusions: We have developed a resource that makes it possible to access the grapevine genome, opening the way to a new era both in grape genetics and breeding and in wine making. The effects of heterozygosity on the assembly have been analyzed and characterized by using several complementary approaches which could be easily transferred to the study of other genomes which present the same features. © 2010 Scalabrin et al; licensee BioMed Central Ltd.},
	keywords = {Chromosome Mapping; Genome, Plant; Vitis; Wine; Vitaceae; Vitis; Vitis vinifera; plant DNA; allele; amino acid sequence; article; computer simulation; contig mapping; cultivar; DNA fingerprinting; genetic linkage; genome analysis; grape; haplotype; heterozygosity; molecular cloning; nonhuman; plant breeding; plant genetics; chromosome map; classification; genetics; grape; plant genome; wine},
	correspondence_address = {M. Morgante; Istituto di Genomica Applicata, Parco Scientifico e Tecnologico di Udine Luigi Danieli, 33100 Udine, Via J Linussio 51, Italy; email: michele.morgante@uniud.it},
	issn = {14712164},
