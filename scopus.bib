	keywords = {Carbon Dioxide; Crops, Agricultural; Illinois; Photosynthesis; Plant Leaves; Soybeans; Illinois; Midwest; United States; Glycine max; carbon dioxide; bioengineering; carbon dioxide; crop yield; ecohydrology; food security; global change; leaf area; plant breeding; yield response; crop; Illinois; photosynthesis; plant leaf; soybean},
	correspondence_address = {P. Kumar; Department of Civil and Environmental Engineering, University of Illinois Urbana Champaign, Urbana, United States; email: kumar1@illinois.edu},
