@ARTICLE{Liang2022,
	author = {Liang, Mang and An, Bingxing and Li, Keanning and Du, Lili and Deng, Tianyu and Cao, Sheng and Du, Yueying and Xu, Lingyang and Gao, Xue and Zhang, Lupei and Li, Junya and Gao, Huijiang},
	title = {Improving Genomic Prediction with Machine Learning Incorporating TPE for Hyperparameters Optimization},
