@ARTICLE{Fita20101049,
	author = {Fita, Ana and Tarín, Néstor and Prohens, Jaime and Rodríguez-Burruezo, Adrián},
	title = {A software tool for teaching backcross breeding simulation},
	year = {2010},
	journal = {HortTechnology},
	volume = {20},
	number = {6},
	pages = {1049 – 1053},
	doi = {10.21273/hortsci.20.6.1049},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-78650775427&doi=10.21273%2fhortsci.20.6.1049&partnerID=40&md5=b7341004df1f2526e57fe3a14eec4321},
	affiliations = {Departamento de Biotecnologi ́a, Universidad Polite ́cnica de Valencia, Valencia 46022, Camino de Vera 14, Spain; IN2, Valencia 46015, Cortes Valencianas 39, Spain},
	abstract = {Plant breeding programs involve multiple steps, and their complete development cannot be experienced by students in a single academic year. Tools of communication and information technologies offer a great opportunity to improve students skills, but only a few software are available for training undergraduate students in plant breeding programs. Here we present a student-friendly software tool, Retromelon, for simulating the backcross breeding method. We also evaluate its suitability and performance as a learning tool. This software is designed to recreate a real melon (Cucumis melo) backcross breeding program aimed at introgressing the resistance to melon vine decline from the tolerant melon cultivar Pat81 into the susceptible cultivar Piel de Sapo. The software simulates the most important steps and decisions that must be made by a plant breeder in a backcross breeding program, including the number of individuals to evaluate in each generation, evaluation of agronomic traits, and selection of individuals. This software is being used by undergraduate horticulture students. Our results have shown that the use of this tool in the classroom increases the motivation of the students, and therefore, benefits the learning process. This software is available upon request both in English and Spanish versions.},
	author_keywords = {Breeding methods; Cucumis melo; Effective learning; Retromelon},
	keywords = {Cucumis; Cucumis melo},
	correspondence_address = {A. Fita; Departamento de Biotecnologi ́a, Universidad Polite ́cnica de Valencia, Valencia 46022, Camino de Vera 14, Spain; email: anfifer@btc.upv.es},
