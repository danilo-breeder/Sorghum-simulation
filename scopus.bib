	author = {Weber, Sven E. and Roscher-Ehrig, Lennard and Kox, Tobias and Abbadi, Amine and Stahl, Andreas and Snowdon, Rod J.},
	title = {Genomic prediction in Brassica napus: evaluating the benefit of imputed whole-genome sequencing data},
	year = {2024},
