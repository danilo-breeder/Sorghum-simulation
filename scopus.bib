	title = {Decomposition of yield gap of soybean in environment × genetics × management in Southern Brazil},
	year = {2023},
	journal = {European Journal of Agronomy},
	volume = {145},
	doi = {10.1016/j.eja.2023.126795},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85148634993&doi=10.1016%2fj.eja.2023.126795&partnerID=40&md5=ac850eccea693474daad7788cfa09c8c},
	affiliations = {Crops Team – Consulting, Research and Development, Roraima, Avenue1000, Hall 61H, Rio Grande do Sul, Santa Maria, Brazil; Departamento de Fitotecnia, Universidade Federal de Santa Maria, Roraima Avenue1000, Hall 77, Rio Grande do Sul, Santa Maria, Brazil},
	abstract = {Estimates and explanations of yield gaps make it possible to increase crop production through improvements in agricultural systems and better crop management. The combination of field data and crop modeling allows scaling the efforts needed to close the yield gap. The objective of this study was to decompose the soybean yield gap into its constituents and to quantify the influence of the main limiting factors on soybean yield in Rio Grande do Sul, Brazil. Yield potentials and water-limited yield potentials were estimated by the CSM-CROPGRO soybean simulation model to quantify the yield gaps related to the choice of cultivar and sowing time, water gap, and gap related to other management practices. We used data from a survey of 853 fields reported by farmers over four growing seasons to quantify yield gaps for each field and the influence of management practices on soybean yields. The annual increase in soybean yield in RS depends on improvements in management (44 %), genetic breeding (42 %) and climate changes (14 %). We identified a gap of 995 kg ha−1 attributed to the choice of cultivar and sowing date, 2006 kg ha−1 attributed to water availability during the developmental cycle and 1437 kg ha−1 attributed to management improvements. A yield gap of 2432 kg ha−1 (genotype × environment gap and management gap) can be closed with adjustments in management practices such as choosing the best cultivar, sowing date, soil pH, P2O5 and K2O fertilization, no-tillage, and summer and winter crop rotation. © 2023 Elsevier B.V.},
	author_keywords = {Crop models; Glycine max (L.) Merr.; Yield potential},
	keywords = {Brazil; Rio Grande do Sul; agricultural management; agricultural modeling; crop production; crop yield; cultivar; plant breeding; sowing date; soybean; water availability},
