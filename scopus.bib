@ARTICLE{Cooper1999153,
	author = {Cooper, M. and Rajatasereekul, S. and Somrith, B. and Sriwisut, S. and Immark, S. and Boonwite, C. and Suwanwongse, A. and Ruangsook, S. and Hanviriyapant, P. and Romyen, P. and Porn-Uraisanit, P. and Skulkhu, E. and Fukai, S. and Basnayake, J. and Podlich, D.W.},
