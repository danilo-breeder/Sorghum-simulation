@ARTICLE{Pérez-Enciso2015,
	author = {Pérez-Enciso, Miguel and Rincón, Juan C and Legarra, Andrés},
	title = {Sequence- vs. chip-assisted genomic selection: Accurate biological information is advised},
	year = {2015},
