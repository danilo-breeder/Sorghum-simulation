	affiliations = {Syngenta Seeds, Inc., Naples, FL 34114, 10290 Greenway Road, United States; Department of Horticultural Science, North Carolina State University, Raleigh, NC 27695-7609, United States; Department of Statistics, North Carolina State University, Raleigh, NC 27695-8203, United States},
