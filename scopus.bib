@ARTICLE{Bančič2024,
	author = {Bančič, J. and Gorjanc, G. and Tolhurst, D.J.},
	title = {A framework for simulating genotype-by-environment interaction using multiplicative models},
	year = {2024},
	journal = {Theoretical and Applied Genetics},
