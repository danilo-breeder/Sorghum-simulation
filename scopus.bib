	keywords = {Computer Simulation; Crosses, Genetic; Genetic Variation; Genomics; Plant Breeding; Selection, Genetic; Triticum; Biodiversity; Drops; Efficiency; Conventional breeding; Genetic diversity; Genomic predictions; Higher efficiency; Number of cycles; Optimal management; Plant breeding programs; Selection accuracy; computer simulation; genetic cross; genetic selection; genetic variation; genetics; genomics; plant breeding; wheat; Genes},
