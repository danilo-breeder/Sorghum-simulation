@ARTICLE{Fu2017,
	author = {Fu, Yong-Bi and Yang, Mo-Hua and Zeng, Fangqin and Biligetu, Bill},
	title = {Searching for an accurate marker-based prediction of an individual quantitative trait in molecular plant breeding},
	year = {2017},
	journal = {Frontiers in Plant Science},
	volume = {8},
