@ARTICLE{Marchais1996257,
	author = {Marchais, L.},
	title = {Parental proportions maximizing the mean value of a parameter in a panmictic population can be useful in plant breeding; [La determination des proportions parentales qui maximisent la valeur moyenne d'un parametre dans une population panmictique peut etre utile en amelioration des plantes]},
