@ARTICLE{Technow2021,
	author = {Technow, Frank and Podlich, Dean and Cooper, Mark},
	title = {Back to the future: Implications of genetic complexity for the structure of hybrid breeding programs},
	year = {2021},
	journal = {G3: Genes, Genomes, Genetics},
	volume = {11},
	number = {7},
	doi = {10.1093/g3journal/jkab153},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85111532300&doi=10.1093%2fg3journal%2fjkab153&partnerID=40&md5=07cbe414a84f2b48e2bc4fbabd703dd4},
	affiliations = {Plant Breeding, Corteva Agriscience, Tavistock, N0B 2R0, ON, Canada; Systems and Innovation for Breeding and Seed Products, Corteva Agriscience, Johnston, 50131, IA, United States; Queensland Alliance for Agriculture and Food Innovation, The University of Queensland, St. Lucia, 4067, QLD, Australia},
	abstract = {Commercial hybrid breeding operations can be described as decentralized networks of smaller, more or less isolated breeding programs. There is further a tendency for the disproportionate use of successful inbred lines for generating the next generation of recombinants, which has led to a series of significant bottlenecks, particularly in the history of the North American and European maize germplasm. Both the decentralization and the disproportionate contribution of inbred lines reduce effective population size and constrain the accessible genetic space. Under these conditions, long-term response to selection is not expected to be optimal under the classical infinitesimal model of quantitative genetics. In this study, we therefore aim to propose a rationale for the success of large breeding operations in the context of genetic complexity arising from the structure and properties of interactive genetic networks. For this, we use simulations based on the NK model of genetic architecture. We indeed found that constraining genetic space through program decentralization and disproportionate contribution of parental inbred lines, is required to expose additive genetic variation and thus facilitate heritable genetic gains under high levels of genetic complexity. These results introduce new insights into why the historically grown structure of hybrid breeding programs was successful in improving the yield potential of hybrid crops over the last century. We also hope that a renewed appreciation for “why things worked” in the past can guide the adoption of novel technologies and the design of future breeding strategies for navigating biological complexity. © The Author(s) 2021. Published by Oxford University Press on behalf of Genetics Society of America.},
	author_keywords = {Breeding strategies; Genetic complexity; Historical properties; Hybrid breeding; Long-term genetic gain},
	keywords = {Crops, Agricultural; Plant Breeding; Zea mays; adoption; article; crop; cross breeding; decentralization; genetic gain; genetic model; genetic variation; inbred strain; nonhuman; quantitative genetics; simulation; crop; genetics; maize; plant breeding},
	correspondence_address = {F. Technow; Plant Breeding, Corteva Agriscience, Tavistock, 596779 County Road 59N, N4S 7W1, Canada; email: frank.technow@corteva.com},
	publisher = {Genetics Society of America},
