@ARTICLE{Stich2007529,
	author = {Stich, Benjamin and Melchinger, Albrecht E. and Piepho, Hans-Peter and Hamrit, Sonia and Schipprack, Wolfgang and Maurer, Hans P. and Reif, Jochen C.},
	title = {Potential causes of linkage disequilibrium in a European maize breeding program investigated with computer simulations},
	year = {2007},
	journal = {Theoretical and Applied Genetics},
	volume = {115},
	number = {4},
	pages = {529 – 536},
	doi = {10.1007/s00122-007-0586-1},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-34547824749&doi=10.1007%2fs00122-007-0586-1&partnerID=40&md5=37493b1875f51e36f72acfe158289c57},
	affiliations = {Institute for Plant Breeding, Seed Science, and Population Genetics, University of Hohenheim, Stuttgart 70593, Germany; Institute for Crop Production and Grassland Research, University of Hohenheim, Stuttgart 70593, Germany; Institute for Molecular Physiology and Biotechnology, University of Rostock, Rostock 18051, Germany},
	abstract = {Knowledge about the forces generating and conserving linkage disequilibrium (LD) is important for drawing conclusions about the prospects and limitations of association mapping. The objectives of our research were to examine the importance of (1) selection, (2) mutation, and (3) genetic drift for generating LD in a typical maize breeding program. We conducted computer simulations based on genotypic data of Central European maize open-pollinated varieties which have played an important role as founders of the European flint heterotic group. The breeding scheme and the dimensioning underlying our simulations reflect essentially the maize breeding program of the University of Hohenheim. Results suggested that in a plant breeding program of the examined dimension and breeding scheme, genetic drift and selection are major forces generating LD. The currently used population-based association mapping tests do not explicitly correct for LD caused by these two forces. Therefore, increased type I error rates are expected if these tests are applied to plant breeding populations. As a consequence, we recommend to use family-based association tests for association mapping approaches in plant breeding populations. © 2007 Springer-Verlag.},
	keywords = {Alleles; Breeding; Chromosome Mapping; Computer Simulation; Europe; Genetic Drift; Linkage Disequilibrium; Minisatellite Repeats; Models, Genetic; Mutation; Quantitative Trait Loci; Selection (Genetics); Variation (Genetics); Zea mays; Zea mays; Computer simulation; Data acquisition; Error analysis; Gene encoding; allele; article; biological model; breeding; chromosome map; comparative study; computer simulation; Europe; gene linkage disequilibrium; genetic drift; genetic selection; genetic variability; genetics; maize; mutation; quantitative trait locus; variable number of tandem repeat; Genetic drift; Linkage disequilibrium (LD); Maize breeding program; Crops},
	correspondence_address = {A.E. Melchinger; Institute for Plant Breeding, Seed Science, and Population Genetics, University of Hohenheim, Stuttgart 70593, Germany; email: melchinger@uni-hohenheim.de},
	issn = {00405752},
	coden = {THAGA},
