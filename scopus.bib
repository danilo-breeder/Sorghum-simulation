@ARTICLE{Ould Estaghvirou2013,
	author = {Ould Estaghvirou, Sidi B. and Ogutu, Joseph O. and Schulz-Streeck, Torben and Knaak, Carsten and Ouzunova, Milena and Gordillo, Andres and Piepho, Hans-Peter},
