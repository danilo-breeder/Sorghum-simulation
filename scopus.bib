@ARTICLE{Bernardo20011,
	author = {Bernardo, R.},
	title = {What if we knew all the genes for a quantitative trait in hybrid crops?},
	year = {2001},
	journal = {Crop Science},
	volume = {41},
	number = {1},
	pages = {1 – 4},
	doi = {10.2135/cropsci2001.4111},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-0035128128&doi=10.2135%2fcropsci2001.4111&partnerID=40&md5=f6592baa510e940d789d6bca63ffa6e7},
	affiliations = {Dep. of Agronomy and Plant Genetics, Univ. of Minnesota, 411 Borlaug Hall, St. Paul, MN 55108-6026, 1991 Buford Circle, United States},
	abstract = {Plant genomics programs are expected to decipher the sequence and function of genes controlling important traits. Most of the important traits in crops are quantitative and are controlled jointly by many loci. What if we knew all the genes for a quantitative trait in hybrid crops? Will genomics enhance hybrid crop breeding, which currently involves selection on the basis of phenotypes rather than gene information? With maize (Zea mays L.) as a model species, I found through computer simulation that gene information is most useful in selection when few loci (e.g., 10) control the trait. With many loci (≥50), the least squares estimates of gene effects become imprecise. Gene information consequently improves selection efficiency among hybrids by only 10% or less, and actually becomes detrimental to selection as more loci become known. Increasing the population size and trait heritability to improve the estimates of gene effects also improves phenotypic selection, leaving little room for improvement of selection efficiency via gene information. The typical reductionist approach in genomics therefore has limited potential for enhancing selection for quantitative traits in hybrid crops.},
	keywords = {computer simulation; genetic improvement; genetic regulation; genetic selection; heritability; hybrid; plant breeding; plant model; quantitative trait; Zea mays},
