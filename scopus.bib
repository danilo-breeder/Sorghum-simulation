@ARTICLE{Picheny20171926,
	author = {Picheny, Victor and Casadebaig, Pierre and Trépos, Ronan and Faivre, Robert and Da Silva, David and Vincourt, Patrick and Costes, Evelyne},
	title = {Using numerical plant models and phenotypic correlation space to design achievable ideotypes},
	year = {2017},
	journal = {Plant Cell and Environment},
	volume = {40},
