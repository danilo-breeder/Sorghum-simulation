@ARTICLE{Malik2018752,
	author = {Malik, W.A. and Hadasch, S. and Forkman, J. and Piepho, H.P.},
	title = {Nonparametric resampling methods for testing multiplicative terms in ammi and gge models for multienvironment trials},
	year = {2018},
