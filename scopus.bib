	keywords = {Agriculture; Genome, Plant; Genomics; Selection (Genetics); Zea mays; Mexico [North America]; North America; Zea mays; Zea mays; agricultural production; breeding; DNA fingerprinting; domestication; genetic differentiation; genomics; maize; morphology; phenotypic plasticity; population bottleneck; selection; agriculture; genetic selection; genetics; genome; genomics; maize; review},
