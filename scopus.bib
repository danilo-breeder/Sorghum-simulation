	correspondence_address = {M. Borzecka-walker; Department of Agrometeorology and Applied Informatics, Institute of Soil Science and Plant Cultivation, State Research Institute, 24-100 Puławy, Czartoryskich 8, Poland; email: mwalker@iung.pulawy.pl},
